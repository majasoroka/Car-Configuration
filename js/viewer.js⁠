/**
 * 3D WebGL Scene Engine (Three.js)
 * Manages the scene lifecycle, lighting, camera controls, and real-time PBR material swaps.
 */
class CarViewer {
    constructor() {
        this.container = document.getElementById('canvas-container');
        this.scene = null;
        this.camera = null;
        this.renderer = null;
        this.controls = null;
        
        // References to customizable meshes
        this.carParts = {
            body: null,
            wheels: [],
            calipers: [],
            interior: null
        };

        this.init();
        this.setupLighting();
        this.buildPlaceholderCar();
        this.animate();
    }

    init() {
        // Initialize Scene
        this.scene = new THREE.Scene();
        this.scene.background = new THREE.Color(0x0a0a0c);
        this.scene.fog = new THREE.FogExp2(0x0a0a0c, 0.015);

        // Initialize Camera
        this.camera = new THREE.PerspectiveCamera(40, this.container.clientWidth / this.container.clientHeight, 0.1, 100);
        this.camera.position.set(5, 2, 5);

        // Initialize WebGL Renderer
        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false, powerPreference: "high-performance" });
        this.renderer.setSize(this.container.clientWidth, this.container.clientHeight);
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        this.renderer.shadowMap.enabled = true;
        this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
        this.renderer.toneMappingExposure = 1.2;
        this.container.appendChild(this.renderer.domElement);

        // Orbit Interaction Controls
        this.controls = new THREE.OrbitControls(this.camera, this.renderer.domElement);
        this.controls.enableDamping = true;
        this.controls.dampingFactor = 0.05;
        this.controls.maxPolarAngle = Math.PI / 2 - 0.02; // Keep camera above ground
        this.controls.minDistance = 3;
        this.controls.maxDistance = 10;

        // Dynamic Resize Handler
        window.addEventListener('resize', () => this.onWindowResize());
    }

    setupLighting() {
        // Ambient illumination
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.2);
        this.scene.add(ambientLight);

        // Studio Overhead Key Light (Generates Soft Shadows)
        const keyLight = new THREE.DirectionalLight(0xffffff, 1.5);
        keyLight.position.set(5, 8, 3);
        keyLight.castShadow = true;
        keyLight.shadow.mapSize.width = 2048;
        keyLight.shadow.mapSize.height = 2048;
        keyLight.shadow.bias = -0.0001;
        this.scene.add(keyLight);

        // Studio Rim/Fill Light (Highlights side curves)
        const fillLight = new THREE.DirectionalLight(0xffffff, 0.8);
        fillLight.position.set(-5, 4, -3);
        this.scene.add(fillLight);

        // Floor Grid/Mirror Ground Reflection Plane
        const floorGeo = new THREE.PlaneGeometry(50, 50);
        const floorMat = new THREE.MeshStandardMaterial({ color: 0x111115, roughness: 0.4, metalness: 0.2 });
        const floor = new THREE.Mesh(floorGeo, floorMat);
        floor.rotation.x = -Math.PI / 2;
        floor.receiveShadow = true;
        this.scene.add(floor);

        // Subtle structural floor grid lines
        const gridHelper = new THREE.GridHelper(40, 40, 0x33333f, 0x1a1a22);
        gridHelper.position.y = 0.01;
        this.scene.add(gridHelper);
    }

    buildPlaceholderCar() {
        const carRootGroup = new THREE.Group();

        // 1. Main Car Chassis/Body
        const bodyGeo = new THREE.BoxGeometry(2.4, 0.6, 1.2);
        // Taper the roofline a bit using standard PBR properties
        const bodyMat = new THREE.MeshStandardMaterial({ color: 0xcc0000, roughness: 0.15, metalness: 0.85 });
        this.carParts.body = new THREE.Mesh(bodyGeo, bodyMat);
        this.carParts.body.position.y = 0.45;
        this.carParts.body.castShadow = true;
        this.carParts.body.receiveShadow = true;
        carRootGroup.add(this.carParts.body);

        // 2. Greenhouse/Cabin/Interior Window block
        const cabinGeo = new THREE.BoxGeometry(1.2, 0.4, 1.0);
        const cabinMat = new THREE.MeshStandardMaterial({ color: 0x1d1d1f, roughness: 0.7, metalness: 0.0 });
        this.carParts.interior = new THREE.Mesh(cabinGeo, cabinMat);
        this.carParts.interior.position.set(-0.1, 0.85, 0);
        this.carParts.interior.castShadow = true;
        carRootGroup.add(this.carParts.interior);

        // 3. Wheel Assembly (4 Positions)
        const wheelPositions = [
            { x: 0.7, y: 0.25, z: 0.65 },  // Front Left
            { x: 0.7, y: 0.25, z: -0.65 }, // Front Right
            { x: -0.7, y: 0.25, z: 0.65 }, // Rear Left
            { x: -0.7, y: 0.25, z: -0.65 } // Rear Right
        ];

        const wheelGeo = new THREE.CylinderGeometry(0.3, 0.3, 0.25, 32);
        wheelGeo.rotateX(Math.PI / 2);
        const wheelMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.5, metalness: 0.8 });

        const caliperGeo = new THREE.BoxGeometry(0.08, 0.15, 0.08);
        const caliperMat = new THREE.MeshStandardMaterial({ color: 0xff0033, roughness: 0.2, metalness: 0.5 });

        wheelPositions.forEach((pos) => {
            const wheelMesh = new THREE.Mesh(wheelGeo, wheelMat);
            wheelMesh.position.set(pos.x, pos.y, pos.z);
            wheelMesh.castShadow = true;
            carRootGroup.add(wheelMesh);
            this.carParts.wheels.push(wheelMesh);

            // Nestle custom brake caliper within wheels
            const caliperMesh = new THREE.Mesh(caliperGeo, caliperMat);
            caliperMesh.position.set(pos.x, pos.y + 0.12, pos.z * 0.85);
            carRootGroup.add(caliperMesh);
            this.carParts.calipers.push(caliperMesh);
        });

        this.scene.add(carRootGroup);
    }

    // Dynamic Material APIs controlled via app.js updates
    updatePaintMaterial(hexColor, roughness, metalness) {
        if (!this.carParts.body) return;
        this.carParts.body.material.color.setHex(parseInt(hexColor.replace('#', '0x')));
        this.carParts.body.material.roughness = roughness;
        this.carParts.body.material.metalness = metalness;
        this.carParts.body.material.needsUpdate = true;
    }

    updateCaliperMaterial(hexColor) {
        this.carParts.calipers.forEach(caliper => {
            caliper.material.color.setHex(parseInt(hexColor.replace('#', '0x')));
            caliper.material.needsUpdate = true;
        });
    }

    updateInteriorMaterial(hexColor, roughness) {
        if (!this.carParts.interior) return;
        this.carParts.interior.material.color.setHex(parseInt(hexColor.replace('#', '0x')));
        this.carParts.interior.material.roughness = roughness;
        this.carParts.interior.material.needsUpdate = true;
    }

    onWindowResize() {
        this.camera.aspect = this.container.clientWidth / this.container.clientHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(this.container.clientWidth, this.container.clientHeight);
    }

    animate() {
        requestAnimationFrame(() => this.animate());
        this.controls.update();
        this.renderer.render(this.scene, this.camera);
    }
}
