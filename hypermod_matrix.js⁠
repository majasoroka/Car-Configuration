    // Structural metadata tracking baseline metrics for all garage bays
    vehicles: {
        "mclaren_f1_1993_by_alex.ka..glb": { hp: 627, speed: 240, weight: "1,138 kg", engine: "6.1L V12", scale: "1 1 1" },
